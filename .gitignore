# OS
.DS_Store

# IDE
.idea/

# Python
__pycache__/
*.pyc
.venv/

# Go build output
/bin/

# Per-worktree sandbox wrappers (E-1281). 'endless sandbox bind' regenerates
# these in each worktree's bin-sandbox/ so they should never be tracked.
/bin-sandbox/

# Symlink to go module cache (created by `just _link-templui`)
internal/web/assets/css/templui

# SQLite binary DB (committed as .sql dump instead)
*.db
*.db-wal
*.db-shm

# Local git worktree checkouts created for parallel sessions
.endless/worktrees/

# Per-worktree companion + ownership lock files (E-1218). Each worktree
# writes its own; main has no business carrying either, but if the
# SessionStart hook ever walks up from a cwd inside main and writes
# them, we don't want them tracked. Layer F's create_task_worktree
# also writes worktree.json into each new worktree's working tree.
.endless/worktree.json
.endless/worktree.lock

# Per-session companion files (E-989)
.endless/sessions/

# Per-worktree isolated test environments (XDG_CONFIG_HOME target for manual sanity)
.test-isolated/

# Go workspace file generated by `just go-work-init` (E-996). Per-developer,
# absolute paths to local go-pkgs co-development checkouts.
go.work
go.work.sum

# Per-worktree Claude Code hook override generated by `just claude-settings-init`
# (E-998). The main checkout commits this file (enabledPlugins); each worktree
# regenerates its own with absolute paths to the worktree's bin/endless-hook.
# This entry is mostly documentary — gitignore does not affect tracked files.
# `git update-index --skip-worktree .claude/settings.json` (run by the recipe)
# is what actually keeps the regenerated content out of a worktree's git status.
.claude/settings.json
