package pages

import "github.com/mikeschinkel/endless/internal/web/components"

templ StubPage(title string, currentPath string) {
	@components.Layout(title, currentPath) {
		<h2 class="text-2xl font-bold text-gray-100 mb-6">{ title }</h2>
		<div class="bg-gray-900 border border-gray-800 rounded-lg px-6 py-12 text-center">
			<p class="text-gray-500 text-lg">Coming soon</p>
			<p class="text-gray-600 text-sm mt-2">This page is under construction.</p>
		</div>
	}
}
